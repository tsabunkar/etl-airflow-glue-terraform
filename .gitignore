# ============================================================
# .gitignore — ETL POC (Airflow + Glue + Terraform)
# ============================================================

# ------------------------------------------------------------
# TERRAFORM
# ------------------------------------------------------------

# Local .terraform directory (downloaded providers & modules)
**/.terraform/
.terraform/
.terraform.lock.hcl

# Terraform state files — NEVER commit these (contain secrets)
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform.tfstate.lock.info

# Terraform variable files that may contain secrets
terraform.tfvars
*.auto.tfvars
*.auto.tfvars.json
# (keep terraform.tfvars.example in source control)

# Terraform plan output files
*.tfplan
*.plan
tfplan

# Terraform crash logs
crash.log
crash.*.log

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config
.terraformrc
terraform.rc

# CDK / Terraform CDK
cdk.out/
cdktf.json
tsconfig.json

# ------------------------------------------------------------
# AWS CREDENTIALS & SECRETS
# ------------------------------------------------------------

# AWS credentials — NEVER commit
.aws/
aws_credentials
credentials
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
*.csr

# Environment files with secrets
.env
.env.*
!.env.example
!.env.template

# Secrets / config files
secrets.yml
secrets.yaml
secrets.json
config/secrets.*
*secret*
*password*
*passwd*
*credential*
*.secret

# ------------------------------------------------------------
# PYTHON
# ------------------------------------------------------------

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/
.env/
.venv*/
virtualenv/
.Python

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/
*.whl
MANIFEST

# pytest / test artifacts
.pytest_cache/
.tox/
.nox/
htmlcov/
.coverage
.coverage.*
coverage.xml
coverage/
*.cover
*.py,cover
nosetests.xml
test-results/
test_output/

# mypy / type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# Pipenv / Poetry
Pipfile.lock
poetry.lock

# Celery
celerybeat-schedule
celerybeat.pid

# SageMath
*.sage.py

# Spyder
.spyderproject.proj
.spyproject

# Rope
.ropeproject

# PyCharm
.idea/

# ------------------------------------------------------------
# AIRFLOW
# ------------------------------------------------------------

# Airflow local DB and config
airflow.db
airflow.cfg
airflow_webserver_stats.pid
standalone_admin_password.txt
webserver_config.py

# Airflow logs (local dev)
logs/
airflow/logs/
airflow/plugins/__pycache__/

# Airflow home (local dev)
~/airflow/

# MWAA local runner
docker-compose.yml
.mwaa_env

# ------------------------------------------------------------
# GLUE / SPARK
# ------------------------------------------------------------

# Spark local checkpoints and temp
spark-warehouse/
derby.log
metastore_db/
checkpoint/
spark-events/

# PySpark temp output
_temporary/
_SUCCESS
part-*.parquet
part-*.csv
part-*.json
*.snappy.parquet
*.snappy

# Local Glue test output
local_output/
glue_output/
test_output/

# AWS Glue bookmark files
*.bookmark

# ------------------------------------------------------------
# DATA FILES — do not commit large data
# ------------------------------------------------------------

# CSV data files (generated by data_generator)
*.csv
*.tsv
!data_generator/sample_small.csv    # allow tiny fixture files

# Parquet, ORC, Avro files
*.parquet
*.orc
*.avro

# JSON output files (generated)
output/
consolidated/
etl_report_*.json
manifest_*.json

# Large archives
*.zip
*.tar
*.tar.gz
*.tar.bz2
*.tgz
*.gz
*.bz2

# ------------------------------------------------------------
# IDE & EDITOR
# ------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr
.idea_modules/

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
*#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# Atom
.atom/

# Eclipse
.project
.classpath
.settings/

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
.AppleDouble
.LSOverride
.DocumentRevisions-V100
.fseventsd
.TemporaryItems
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.nfs*

# ------------------------------------------------------------
# DOCKER (if used locally for Airflow dev)
# ------------------------------------------------------------

docker-compose.override.yml
.docker/
.dockerignore

# ------------------------------------------------------------
# LOGS & TEMP FILES
# ------------------------------------------------------------

*.log
*.logs
*.tmp
*.temp
*.bak
*.orig
*.pid
*.seed
*.pid.lock
tmp/
temp/
cache/
.cache/

# ------------------------------------------------------------
# TERRAFORM DOCS / GENERATED FILES
# ------------------------------------------------------------

# terraform-docs generated
TERRAFORM_DOCS.md

# checkov / tfsec reports
checkov_report/
tfsec_report/
*.sarif

# infracost
.infracost/
infracost.json

# ------------------------------------------------------------
# CI/CD
# ------------------------------------------------------------

# GitHub Actions local test runner (act)
.act/

# CircleCI local
.circleci/local/

# ------------------------------------------------------------
# MISC
# ------------------------------------------------------------

# Node (if any helper scripts use it)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/

# Local test / scratch files
scratch/
sandbox/
playground/
*.scratch.*
todo.txt
notes.txt
NOTES.md